{
  "version": "2.0.0",
  "inputs": [
    {
      "id": "vcvarsPath",
      "type": "promptString",
      "description": "Path to vcvars64.bat",
      "default": "C:\\Program Files\\Microsoft Visual Studio\\2022\\Community\\VC\\Auxiliary\\Build\\vcvars64.bat"
    }
  ],
  "options": {
    "shell": {
      "executable": "cmd.exe",
      "args": [
        "/c"
      ]
    }
  },
  "tasks": [
    {
      "label": "configure:msvc-multi",
      "type": "shell",
      "command": "\"${input:vcvarsPath}\" && cmake --preset msvc-multi",
      "problemMatcher": []
    },
    {
      "label": "build:Debug",
      "type": "shell",
      "command": "\"${input:vcvarsPath}\" && cmake --build --preset build-Debug -j",
      "problemMatcher": [
        "$msCompile"
      ],
    },
    {
      "label": "build:RelWithDebInfo",
      "type": "shell",
      "command": "\"${input:vcvarsPath}\" && cmake --build --preset build-RelWithDebInfo -j",
      "problemMatcher": [
        "$msCompile"
      ],
    },
    {
      "label": "build:Release",
      "type": "shell",
      "command": "\"${input:vcvarsPath}\" && cmake --build --preset build-Release -j",
      "problemMatcher": [
        "$msCompile"
      ],
    },
    {
      "label": "test:Debug",
      "type": "shell",
      "command": "\"${input:vcvarsPath}\" && ctest --preset test-Debug",
      "problemMatcher": [],
      "dependsOn": "build:Debug"
    },
    {
      "label": "test:Release",
      "type": "shell",
      "command": "\"${input:vcvarsPath}\" && ctest --preset test-Release",
      "problemMatcher": [],
      "dependsOn": "build:Release"
    },
    {
      "label": "run:holovibes:Debug",
      "type": "shell",
      "command": "build\\msvc-multi\\Debug\\holovibes.exe",
      "problemMatcher": [],
      "dependsOn": "build:Debug"
    },
    {
      "label": "run:holovibes:RelWithDebInfo",
      "type": "shell",
      "command": "build\\msvc-multi\\RelWithDebInfo\\holovibes.exe",
      "problemMatcher": [],
      "dependsOn": "build:RelWithDebInfo"
    },
    {
      "label": "run:holovibes:Release",
      "type": "shell",
      "command": "build\\msvc-multi\\Release\\holovibes.exe",
      "problemMatcher": [],
      "dependsOn": "build:Release"
    }
  ]
}