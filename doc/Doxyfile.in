PROJECT_NAME           = "@PROJECT_NAME@"
PROJECT_NUMBER                  = "@PROJECT_VERSION@"

OUTPUT_DIRECTORY                = "@CMAKE_CURRENT_BINARY_DIR@/doxygen"
GENERATE_HTML                   = YES
GENERATE_LATEX                  = NO

# Input: headers and sources
INPUT                           = @DOXYGEN_INPUT_JOINED@
RECURSIVE                       = YES
FILE_PATTERNS                 = *.h *.hh *.hpp *.hxx *.c *.cc *.cpp *.cxx *.cu *.cuh *.md
EXTENSION_MAPPING             = hh=C++ hxx=C++ cuh=C++ cu=C++

MARKDOWN_SUPPORT              = YES
USE_MDFILE_AS_MAINPAGE        = "@CMAKE_SOURCE_DIR@/README.md"

EXTRACT_ALL                   = YES
EXTRACT_PRIVATE               = NO
WARN_IF_UNDOCUMENTED          = YES

# Warns
WARN_IF_UNDOCUMENTED            = YES
WARN_AS_ERROR                   = NO